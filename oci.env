# OCI Configuration
OCI_CONFIG=/home/ubuntu/oracle-freetier-instance-creation/oci_config
OCT_FREE_AD=AD-1
DISPLAY_NAME=my-arm-ubuntu-instance

# Shape Settings (यहाँ हमने 4 Core और 24GB RAM सेट कर दिया है)
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex
OCI_COMPUTE_OCPUS=4
OCI_COMPUTE_MEMORY_IN_GBS=24

SECOND_MICRO_INSTANCE=False
REQUEST_WAIT_TIME_SECS=60
SSH_AUTHORIZED_KEYS_FILE=/home/ubuntu/oracle-freetier-instance-creation/id_rsa.pub

# यहाँ अपनी ओरेकल वाली सबनेट ID पेस्ट करें
OCI_SUBNET_ID=ocid1.vcn.oc1.ap-mumbai-1.amaaaaaazeqh65iazc76quofuugopnn5tgbgaak5lu6o56a2sdkyb7eqefda

OCI_IMAGE_ID=
OPERATING_SYSTEM="Canonical Ubuntu"
OS_VERSION=22.04

# इसे true करना मत भूलना ताकि इंटरनेट चल सके
ASSIGN_PUBLIC_IP=true

# स्टोरेज को पूरे 200GB पर सेट कर दिया
BOOT_VOLUME_SIZE=200
